generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(cuid())
  name     String?
  username String  @unique
  email    String  @unique
  password String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cvs CV[]
}

model CV {
  id String @id @default(cuid())

  title   String
  summary String?

  template   String @default("modern")
  themeColor String @default("blue")
  font       String @default("inter")

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile Profile?

  educations   Education[]
  experiences  Experience[]
  projects     Project[]
  skills       Skill[]
  languages    Language[]
  certificates Certificate[]
  interests    Interest[]

  @@index([userId])
}

model Profile {
  id String @id @default(cuid())

  photo String?

  fullName String?

  jobTitle String?

  email String?

  phone String?

  location String?

  linkedin String?

  github String?

  about String?

  cvId String @unique

  cv CV @relation(fields: [cvId], references: [id], onDelete: Cascade)
}

model Education {
  id String @id @default(cuid())

  school String

  degree String

  field String

  startYear Int

  endYear Int?

  cvId String

  cv CV @relation(fields: [cvId], references: [id], onDelete: Cascade)
}
model Experience {
  id String @id @default(cuid())

  company String

  position String

  description String?

  startDate DateTime

  endDate DateTime?

  cvId String

  cv CV @relation(fields: [cvId], references: [id], onDelete: Cascade)
}

model Skill {
  id String @id @default(cuid())

  name String

  level String?

  cvId String

  cv CV @relation(fields: [cvId], references: [id], onDelete: Cascade)
}

model Project {
  id String @id @default(cuid())

  name String

  description String?

  githubUrl String?

  demoUrl String?

  cvId String

  cv CV @relation(fields: [cvId], references: [id], onDelete: Cascade)
}

model Language {
  id String @id @default(cuid())

  name String

  level String?

  cvId String

  cv CV @relation(fields: [cvId], references: [id], onDelete: Cascade)
}

model Certificate {
  id String @id @default(cuid())

  name String

  issuer String?

  date String?

  url String?

  cvId String

  cv CV @relation(fields: [cvId], references: [id], onDelete: Cascade)
}

model Interest {
  id String @id @default(cuid())

  name String

  cvId String

  cv CV @relation(fields: [cvId], references: [id], onDelete: Cascade)
}
